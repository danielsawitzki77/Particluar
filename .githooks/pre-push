#!/bin/sh
# Pre-push hook: runs build verification for both Debug and Release.
# Install with: git config core.hooksPath .githooks
# Bypass with:  git push --no-verify

# Find the repo root (works from any subdirectory)
REPO_ROOT="$(git rev-parse --show-toplevel)"

echo "Running pre-push build verification..."

# Call the batch script (Windows environment)
cmd.exe /c "$REPO_ROOT/scripts/pre-push-check.bat"
RESULT=$?

if [ $RESULT -ne 0 ]; then
    echo ""
    echo "Pre-push check FAILED. Fix build errors before pushing."
    exit 1
fi

exit 0